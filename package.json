{
  "name": "quantum-coin-js-sdk",
  "version": "2.1.1",
  "description": "Quantum Coin - Q SDK in JavaScript",
  "main": "index.js",
  "scripts": {
    "test": "node --test tests/non-transactional.preinit.test.js tests/non-transactional.test.js tests/sign-raw-transaction.test.js tests/sign-verify.test.js tests/hashing.test.js tests/get-gas-price.test.js tests/sign-raw-keytype5-context-null.test.js tests/transactional.rpc.test.js",
    "test:browser": "node scripts/build-browser-tests.js && node tests/browser/run-browser.js",
    "test:all": "npm test && npm run test:browser",
    "build": "npx -p typescript tsc index.js --declaration --allowJs --emitDeclarationOnly",
    "build:wasm": "node scripts/build-wasm.js --local",
    "build:wasm:file": "node scripts/build-wasm.js --base64-file",
    "build:wasm:url": "node scripts/build-wasm.js --base64-url"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantumcoinproject/quantum-coin-js-sdk.git"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "wasm_exec.js",
    "wasm_exec.d.ts",
    "wasmBase64.js",
    "wasmBase64.d.ts",
    "LICENSE-wasm_exec.js.txt"
  ],
  "keywords": [
    "pqc",
    "cryptography",
    "quantum coins",
    "quantum coin",
    "quantumcoin",
    "blockchain"
  ],
  "author": "Quantum Coin Community",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/quantumcoinproject/quantum-coin-js-sdk/issues"
  },
  "homepage": "https://github.com/quantumcoinproject/quantum-coin-js-sdk#readme",
  "dependencies": {
    "seed-words": "1.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1"
  }
}
